<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
        Íconos oscuros sobre status/navigation bar en modo claro. Complementa a
        enableEdgeToEdge() (MainActivity), que es quien realmente maneja el contraste
        de forma dinámica; estos flags XML solo cubren el primer frame (antes de que
        corra el código Kotlin) para evitar un parpadeo con el contraste invertido.
    -->
    <style name="Theme.Dokusho" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
    </style>
</resources>
