  },
  {
   "oraciones": [
    {
     "texto": "「おれあ、このごろ、とてもふしぎなことがあるんだ」",
     "furigana": [],
     "traduccion": null
    }
   ]
  },
  {
   "oraciones": [
    {
     "texto": "「何が？」",
     "furigana": [],
     "traduccion": null
    }
   ]
  },
  {
   "oraciones": [
    {
     "texto": "「おっ母が死んでからは、だれだか知らんが、おれに栗やまつたけなんかを、まいにちまいにちくれるんだよ」",
     "furigana": [],
